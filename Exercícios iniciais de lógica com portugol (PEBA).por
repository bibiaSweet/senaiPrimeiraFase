programa {
  funcao inicio() {
    real vitoria
    real empate
    real pontos
    escreva ("Digite o número de vitórias:")
    leia (vitoria)
    escreva ("\nDigite o numero de empates:")
    leia (empate)
    pontos = (vitoria * 3 ) + empate
    escreva ( "\nQuantidade de pontos:" , pontos) 

  }
}
