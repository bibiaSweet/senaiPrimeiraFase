programa {
  funcao inicio() {
    inteiro peso = 60
    inteiro distancia = 1000 
    real volume = 0.5
    real frete
    escreva ("peso: " + peso +"kg")
    escreva ("\ndistancia: " + distancia + "km")
    escreva ("\nvolume: "+ volume + "m3")
    escreva ("\nfrete = R$ ") 
    escreva (15+(2*peso)+(0.05*distancia)+(10*volume))
    
    
      }
}
