programa {
  funcao inicio() {
    inteiro idadeEmAnosCaninos
    inteiro idadeEmAnosHumanos

    escreva ("Digite a idade do seu cachorro: " )
    leia (idadeEmAnosCaninos)
    
        idadeEmAnosHumanos = idadeEmAnosCaninos * 7 


    se (idadeEmAnosHumanos >= 65){
      escreva ("\nAPOSENTADORIA APROVADA")
      }
      senao {
        escreva ("\nAPOSENTADORIA NEGADA")




    }


    





  }
}
