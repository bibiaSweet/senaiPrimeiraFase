programa {
  funcao inicio() {
   real inicial
    real final
    real total 
    escreva ("Quantidade inicial de laranjas:")
    leia (inicial)
    escreva ("Quantidade final de laranjas:")
    leia (final)
    total = inicial - final
    escreva ("\nTotal de laranjas vendidas no dia são:" + total ) 
  }
}
